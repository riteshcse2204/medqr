// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── TENANT ────────────────────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  name        String
  domain      String?  @unique
  plan        String   @default("BASIC")
  isActive    Boolean  @default(true)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  users        User[]
  patients     Patient[]
  doctors      Doctor[]
  appointments Appointment[]
  bills        Bill[]
  medicines    Medicine[]
  encounters   Encounter[]
  prescriptions Prescription[]
  wards        Ward[]
  beds         Bed[]
  admissions   IpdAdmission[]
  labOrders    LabOrder[]
  suppliers    Supplier[]
  purchaseOrders PurchaseOrder[]
  branches     Branch[]

  @@map("tenants")
}

// ─── BRANCH ────────────────────────────────────────────────────────────────

model Branch {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  isMain      Boolean  @default(false)

  users        User[]
  patients     Patient[]
  doctors      Doctor[]
  appointments Appointment[]
  bills        Bill[]
  medicines    Medicine[]
  encounters   Encounter[]
  prescriptions Prescription[]
  wards        Ward[]
  beds         Bed[]
  admissions   IpdAdmission[]
  labOrders    LabOrder[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("branches")
}

// ─── USER ───────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  email      String   @unique
  password   String
  name       String
  phone      String?
  role       String     @default("RECEPTIONIST")
  isActive   Boolean  @default(true)
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  staffProfile StaffProfile?

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("users")
}

// ─── HR & STAFF ─────────────────────────────────────────────────────────────

model StaffProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  designation  String
  department   String?
  salary       Float    @default(0)
  joinDate     DateTime @default(now())
  bankAccount  String?
  panNumber    String?
  documents    String?    // Array of {name, url}
  
  attendance   Attendance[]
  payroll      Payroll[]

  @@map("staff_profiles")
}

model Attendance {
  id             String   @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id])
  date           DateTime @default(now())
  checkIn        DateTime?
  checkOut       DateTime?
  status         String @default("PRESENT")

  @@map("attendance")
}

model Payroll {
  id             String   @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id])
  month          Int
  year           Int
  basicSalary    Float
  allowances     Float    @default(0)
  deductions     Float    @default(0)
  netSalary      Float
  status         String @default("PENDING")
  paidAt         DateTime?

  @@map("payroll")
}


model IpdAdmission {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  bedId       String
  bed         Bed      @relation(fields: [bedId], references: [id])

  admissionDate DateTime @default(now())
  dischargeDate DateTime?
  status        String @default("ADMITTED")
  reason        String?
  notes         String?

  createdBy  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@map("ipd_admissions")
}

model LabOrder {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  
  testName    String
  status      String   @default("PENDING")
  result      String?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("lab_orders")
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  gstin       String?
  
  orders      PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  orderNo     String
  status      String   @default("PENDING")
  totalAmount Float
  notes       String?
  items       String?    
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("purchase_orders")
}

model IotDevice {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  name        String
  type        String
  macAddress  String   @unique
  isActive    Boolean  @default(true)
  lastSeen    DateTime?
  
  readings    IotReading[]

  @@map("iot_devices")
}

model IotReading {
  id          String   @id @default(cuid())
  deviceId    String
  device      IotDevice @relation(fields: [deviceId], references: [id])
  patientId   String?
  value       String      
  timestamp   DateTime @default(now())

  @@map("iot_readings")
}

// ─── PATIENT ───────────────────────────────────────────────────────────────

model Patient {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  name        String
  phone       String
  email       String?
  abhaId      String?
  abhaHistory String?    
  gender      String
  dob         DateTime?
  bloodGroup  String?
  address     String?
  
  appointments Appointment[]
  encounters   Encounter[]
  prescriptions Prescription[]
  admissions   IpdAdmission[]
  labOrders    LabOrder[]

  createdBy  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, phone])
  @@map("patients")
}

// ─── DOCTOR ─────────────────────────────────────────────────────────────────

model Doctor {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id])
  name            String
  specialization  String
  phone           String?
  email           String?
  registrationNo  String?
  consultFee      Float    @default(0)
  isActive        Boolean  @default(true)

  appointments    Appointment[]
  encounters      Encounter[]
  prescriptions   Prescription[]
  admissions      IpdAdmission[]
  labOrders       LabOrder[]

  createdBy  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("doctors")
}

// ─── APPOINTMENT ────────────────────────────────────────────────────────────

model Appointment {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])

  date        DateTime
  timeSlot    String?
  status      String @default("SCHEDULED")
  type        String @default("OPD")
  reason      String?
  notes       String?

  telemedicineSession TelemedicineSession?

  createdBy  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([tenantId, date(sort: Desc)])
  @@map("appointments")
}

// ─── CLINICAL ───────────────────────────────────────────────────────────────

model Encounter {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])

  chiefComplaints String?
  diagnosis       String?
  vitals          String?    // {bp: '120/80', temp: '98.6', weight: '70kg'}
  notes           String?

  prescription    Prescription?

  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("encounters")
}

model Prescription {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  doctorId     String
  doctor       Doctor   @relation(fields: [doctorId], references: [id])
  encounterId  String?  @unique
  encounter    Encounter? @relation(fields: [encounterId], references: [id])

  medicines    String     // Array of {medicineId, name, dosage, duration, instructions}
  notes        String?
  status       String   @default("ACTIVE")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("prescriptions")
}

// ─── BILLING ────────────────────────────────────────────────────────────────

model Bill {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  patientId    String
  patient      Patient     @relation(fields: [patientId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  billNo       String
  totalAmount  Float
  taxableAmount Float      @default(0)
  cgst         Float       @default(0)
  sgst         Float       @default(0)
  igst         Float       @default(0)
  paidAmount   Float       @default(0)
  discount     Float       @default(0)
  status       String  @default("PENDING")
  paymentMode  String?
  transactionId String?    
  irn          String?     
  ackNo        String?     
  notes        String?

  items        BillItem[]
  payments     Payment[]

  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([tenantId, patientId, createdAt(sort: Desc)])
  @@map("bills")
}

model BillItem {
  id          String  @id @default(cuid())
  billId      String
  bill        Bill    @relation(fields: [billId], references: [id])
  description String
  hsnCode     String?
  quantity    Int     @default(1)
  unitPrice   Float
  gstRate     Float   @default(0) 
  gstAmount   Float   @default(0)
  total       Float

  @@map("bill_items")
}

model Payment {
  id            String   @id @default(cuid())
  billId        String
  bill          Bill     @relation(fields: [billId], references: [id])
  amount        Float
  method        String   
  provider      String?  
  transactionId String?
  status        String   
  createdAt     DateTime @default(now())

  @@map("payments")
}

// ─── PHARMACY ───────────────────────────────────────────────────────────────

model Medicine {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  name         String
  genericName  String?
  category     String?
  manufacturer String?
  price        Float
  stock        Int      @default(0)
  minStock     Int      @default(10)
  expiryDate   DateTime?
  isActive     Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@map("medicines")
}

// ─── IPD ────────────────────────────────────────────────────────────────────

model Ward {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  name        String
  type        String @default("GENERAL")
  floor       String?

  beds        Bed[]

  createdBy  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@map("wards")
}

model Bed {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  wardId      String
  ward        Ward     @relation(fields: [wardId], references: [id])
  bedNumber   String
  status      String @default("AVAILABLE")

  admissions  IpdAdmission[]

  @@map("beds")
}

model TelemedicineSession {
  id             String      @id @default(cuid())
  appointmentId  String      @unique
  appointment    Appointment @relation(fields: [appointmentId], references: [id])
  roomName       String      @unique
  token          String?
  status         String @default("SCHEDULED")
  startedAt      DateTime?
  endedAt        DateTime?

  @@map("telemedicine_sessions")
}
